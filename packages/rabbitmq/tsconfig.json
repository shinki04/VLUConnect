{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "watch": true,
  "devDependencies": {
    "@repo/typescript-config": "workspace:*"
  },
  "include": ["src/**/*.ts"],

  "exclude": ["node_modules", "dist"]
}
