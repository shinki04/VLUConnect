{
    "$schema": "https://turborepo.com/schema.json",
    "ui": "tui",
    "globalDependencies": [
        ".env*"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "$TURBO_DEFAULT$",
                ".env*"
            ],
            "outputs": [
                ".next/**",
                "!.next/cache/**",
                "dist/**"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "check-types": {
            "dependsOn": [
                "^check-types"
            ]
        },
        "start": {
            "dependsOn": [
                "^build"
            ],
            "cache": false,
            "persistent": true
        },
        "dev": {
            "inputs": [
                "$TURBO_DEFAULT$",
                ".env*"
            ],
            "cache": false,
            "persistent": true
        }
    }
}