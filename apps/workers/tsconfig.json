{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "moduleResolution": "NodeNext",
    "paths": {
      "@/*": ["./src/*"] // Cho phép import từ apps/web
    }
  },
  "watch": true,
  "include": ["src/**/*.ts", "src/**/*.tsx"],

  "exclude": ["node_modules", "dist"]
}
